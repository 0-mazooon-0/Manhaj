@model Manhaj.Models.Course
@{
    ViewData["Title"] = "إدارة: " + Model.Title;
    Layout = "_DashboardLayout";
}

<section class="section" style="background: var(--background-gray); min-height: 80vh; padding: 40px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background: #d4edda; color: #155724; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Course Header -->
        <div class="dashboard-card" style="margin-bottom: 30px;">
            <h2 class="section-title" style="margin-bottom: 10px;">@Model.Title</h2>
            <p style="color: var(--text-secondary); margin-bottom: 15px;">@(Model.Description ?? "لا يوجد وصف")</p>
            
            <div style="display: flex; gap: 30px; margin-top: 20px;">
                <div>
                    <div style="font-size: 28px; font-weight: 700; color: var(--primary-color);">@Model.Lectures.Count</div>
                    <div style="color: var(--text-secondary);">محاضرة</div>
                </div>
                <div>
                    <div style="font-size: 28px; font-weight: 700; color: var(--primary-color);">@Model.Course_Registrations.Count</div>
                    <div style="color: var(--text-secondary);">طالب مسجل</div>
                </div>
                <div>
                    <div style="font-size: 28px; font-weight: 700; color: var(--primary-color);">@Model.Price.ToString("N0")</div>
                    <div style="color: var(--text-secondary);">جنيه</div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div style="margin-bottom: 30px; display: flex; gap: 15px;">
            <a class="btn btn-primary" asp-controller="Lecture" asp-action="Create" asp-route-courseId="@Model.Id">
                <span style="font-size: 20px; margin-left: 8px;">+</span> إضافة محاضرة
            </a>
            <a class="btn btn-outline" style="border: 2px solid var(--primary-color); color: var(--primary-color);" 
               asp-controller="Teacher" asp-action="EditCourse" asp-route-id="@Model.Id">
                ✏️ تعديل الدورة
            </a>
            <form asp-controller="Teacher" asp-action="DeleteCourse" asp-route-id="@Model.Id" method="post" 
                  onsubmit="return confirm('هل أنت متأكد من حذف هذه الدورة؟ سيتم حذف جميع المحاضرات والاختبارات المرتبطة بها.');" 
                  style="display: inline;">
                <button type="submit" class="btn btn-outline" style="border: 2px solid #dc3545; color: #dc3545;">
                    🗑️ حذف الدورة
                </button>
            </form>
        </div>

        <!-- Lectures List -->
        <div class="dashboard-card">
            <h3 class="section-title" style="font-size: 24px; margin-bottom: 20px;">المحاضرات</h3>
            
            @if (Model.Lectures.Any())
            {
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    @foreach (var lecture in Model.Lectures.OrderBy(l => l.Id))
                    {
                        <div style="background: var(--background-gray); padding: 20px; border-radius: 12px;">
                            <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 10px;">
                                <div style="flex: 1;">
                                    <h4 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">@lecture.Title</h4>
                                    <p style="color: var(--text-secondary); margin-bottom: 10px;">@lecture.Description</p>
                                    <div style="display: flex; gap: 20px; color: var(--text-secondary); font-size: 14px;">
                                        <span>📹 <a href="@lecture.VideoUrl" target="_blank" style="color: var(--primary-color);">رابط الفيديو</a></span>
                                        <span>📄 @lecture.Materials.Count مادة تعليمية</span>
                                        @if (lecture.Assignment != null)
                                        {
                                            <span>📝 واجب</span>
                                        }
                                    </div>
                                </div>
                                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                                        @if (lecture.Assignment == null)
                                        {
                                            <a class="btn btn-outline" style="padding: 8px 16px; font-size: 14px; color: var(--primary-color); border-color: var(--primary-color);" 
                                               asp-controller="Assignment" asp-action="Create" asp-route-lectureId="@lecture.Id">
                                                + واجب
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-outline" style="padding: 8px 16px; font-size: 14px; color: #28a745; border-color: #28a745;" 
                                               asp-controller="Assignment" asp-action="Details" asp-route-id="@lecture.Assignment.Id">
                                                عرض الواجب
                                            </a>
                                        }

                                        @if (lecture.Quiz == null)
                                        {
                                            <a class="btn btn-outline" style="padding: 8px 16px; font-size: 14px; color: var(--secondary-color); border-color: var(--secondary-color);" 
                                               href="@Url.Action("CreateWizard", "Quiz", new { lectureId = lecture.Id })">
                                                + اختبار
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-outline" style="padding: 8px 16px; font-size: 14px; color: var(--secondary-color); border-color: var(--secondary-color);" 
                                               href="@Url.Action("Details", "Quiz", new { id = lecture.Quiz.Id })">
                                                عرض الاختبار
                                            </a>
                                        }

                                        <a class="btn btn-primary" style="padding: 8px 16px; font-size: 14px;" 
                                           asp-controller="Lecture" asp-action="Edit" asp-route-id="@lecture.Id">
                                            تعديل
                                        </a>
                                    </div>
                            </div>

                            @if (lecture.Materials.Any())
                            {
                                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e0e0e0;">
                                    <strong style="display: block; margin-bottom: 10px;">المواد التعليمية:</strong>
                                    @foreach (var material in lecture.Materials)
                                    {
                                        <div style="padding: 8px; background: white; border-radius: 6px; margin-bottom: 8px;">
                                            📎 @material.Title (@material.Filetype)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="text-align: center; color: var(--text-secondary); padding: 40px;">
                    لم تقم بإضافة أي محاضرات بعد. ابدأ بإضافة محاضرة الآن!
                </p>
            }
        </div>

        <!-- Enrolled Students -->
        <div class="dashboard-card" style="margin-top: 30px;">
            <h3 class="section-title" style="font-size: 24px; margin-bottom: 20px;">الطلاب المسجلين</h3>
            
            @if (Model.Course_Registrations.Any())
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px;">
                    @foreach (var registration in Model.Course_Registrations)
                    {
                        <div style="background: var(--background-gray); padding: 15px; border-radius: 8px;">
                            <div style="font-weight: 600; margin-bottom: 5px;">
                                @registration.Student.FirstName @registration.Student.LastName
                            </div>
                            <div style="color: var(--text-secondary); font-size: 14px;">
                                @registration.Student.Email<br/>
                                @registration.Student.Level
                            </div>
                            <div style="margin-top: 10px; padding-top: 10px; border-top: 1px solid #e0e0e0;">
                                @{
                                    var progress = ((Dictionary<int, int>)ViewBag.StudentProgress).ContainsKey(registration.StudentId) 
                                        ? ((Dictionary<int, int>)ViewBag.StudentProgress)[registration.StudentId] 
                                        : 0;
                                }
                                <div style="font-size: 14px; color: var(--text-secondary);">
                                    التقدم: @progress%
                                </div>
                                <div style="background: #e0e0e0; height: 6px; border-radius: 3px; margin-top: 5px;">
                                    <div style="background: var(--primary-color); height: 100%; border-radius: 3px; width: @progress%;"></div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="text-align: center; color: var(--text-secondary); padding: 40px;">
                    لا يوجد طلاب مسجلين في هذه الدورة بعد
                </p>
            }
        </div>
    </div>
</section>

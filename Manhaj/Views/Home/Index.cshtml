@{
    ViewData["Title"] = "منهج - منهجك نحو التفوق التعليمي";
    Layout = null;
}

<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/css/styles.css">
  <style>
    /* Magic Book Animations and Styles */
    .magic-hero-section { width: 100%; min-height: 80vh; position: relative; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: space-between; padding-top: 6rem; padding-bottom: 2rem; background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 50%, #60a5fa 100%); margin-top: 0; box-sizing: border-box; }
    .magic-header { text-align: center; z-index: 10; pointer-events: none; margin-bottom: 1rem; }
    .magic-title { color: white; font-size: 2.5rem; font-weight: bold; margin: 0; font-family: 'Tajawal', sans-serif; text-shadow: 2px 2px 8px rgba(0,0,0,0.3); }
    .magic-hint { color: rgba(255,255,255,0.8); margin-top: 10px; font-size: 0.875rem; animation: pulseText 2s infinite; text-align: center; pointer-events: none; }
    @@keyframes pulseText { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
    
    .book-container { perspective: 1000px; width: 200px; height: 280px; margin: 2rem 0 3rem 0; cursor: pointer; z-index: 100; animation: bookFloat 4s ease-in-out infinite; }
    @@keyframes bookFloat { 0%, 100% { transform: translateY(0px); } 50% { transform: translateY(-15px); } }
    .book { position: relative; width: 100%; height: 100%; transform-style: preserve-3d; }
    .book-cover { position: absolute; width: 100%; height: 100%; border-radius: 0 8px 8px 0; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 50%, #1e40af 100%); box-shadow: -5px 5px 15px rgba(0, 0, 0, 0.3), inset -2px 0 10px rgba(0, 0, 0, 0.1); display: flex; flex-direction: column; align-items: center; justify-content: center; transform-origin: left; transition: transform 0.8s ease-out; z-index: 10; transform-style: preserve-3d; backface-visibility: hidden; }
    .book-cover::after { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 50%, #1e40af 100%); border-radius: 0 8px 8px 0; transform: rotateY(180deg) translateZ(1px); backface-visibility: hidden; }
    .book.opened .book-cover { transform: rotateY(-180deg); }
    .book-spine { position: absolute; left: 0; width: 20px; height: 100%; transform: rotateY(-90deg) translateX(-10px); border-radius: 2px 0 0 2px; z-index: 8; }
    .book-pages { position: absolute; right: 2px; width: 190px; height: 270px; top: 5px; background: linear-gradient(90deg, #f5f5f5 0%, #fff 10%, #f0f0f0 20%, #fff 30%, #f5f5f5 40%, #fff 50%, #f0f0f0 60%, #fff 70%, #f5f5f5 80%, #fff 90%, #f0f0f0 100%); border-radius: 0 6px 6px 0; transform: translateZ(1px); z-index: 6; }
    .book-pages-content { position: absolute; right: 2px; width: 190px; height: 270px; top: 5px; background: #fff; border-radius: 0 6px 6px 0; transform: translateZ(1px); z-index: 7; display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
    .book.opened .book-pages-content { opacity: 1; transition-delay: 0.4s; }
    .quran-verse { text-align: center; }
    .verse-text { font-family: 'Amiri', serif; font-size: 1.8rem; font-weight: 700; color: #1e3a8a; margin: 0; line-height: 1.8; letter-spacing: 0.5px; }
    .verse-number { font-family: 'Tajawal', sans-serif; font-size: 0.9rem; color: #64748b; margin-top: 15px; margin-bottom: 0; }
    .book-title { font-family: 'Amiri', serif; font-size: 3rem; font-weight: 700; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2); color: white; }
    .book-decoration { width: 120px; height: 3px; margin: 15px 0; border-radius: 2px; background-color: #facc15; }
    .book-subtitle { font-family: 'Tajawal', sans-serif; font-size: 0.9rem; opacity: 0.9; color: #dbeafe; }
    .floating-letter { position: fixed; font-family: 'Amiri', serif; font-weight: 700; pointer-events: none; z-index: 1000; animation: floatUp 3s ease-out forwards; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2); }
    @@keyframes floatUp { 0% { opacity: 1; transform: translateY(0) rotate(0deg) scale(1); } 50% { opacity: 0.8; } 100% { opacity: 0; transform: translateY(-400px) rotate(360deg) scale(0.3); } }
    .book:hover { filter: drop-shadow(0 0 20px rgba(59, 130, 246, 0.5)); }
    .sparkle { position: fixed; width: 8px; height: 8px; border-radius: 50%; pointer-events: none; z-index: 999; animation: sparkleAnim 1s ease-out forwards; }
    @@keyframes sparkleAnim { 0% { opacity: 1; transform: scale(1); } 100% { opacity: 0; transform: scale(0); } }

    /* Custom Layout Classes connecting user utility classes */
    .cover-dec-top { position: absolute; top: 1rem; width: 8rem; height: 0.25rem; background-color: #facc15; border-radius: 0.25rem; opacity: 0.8; }
    .cover-dec-bottom { position: absolute; bottom: 1rem; width: 8rem; height: 0.25rem; background-color: #facc15; border-radius: 0.25rem; opacity: 0.8; }
    .cover-border { position: absolute; top: 1rem; right: 1rem; bottom: 1rem; left: 1rem; border: 2px solid rgba(250, 204, 21, 0.3); border-radius: 0.25rem; pointer-events: none; }
    .cover-icon { position: absolute; width: 1.5rem; height: 1.5rem; color: #facc15; opacity: 0.6; }
    .ci-tr { top: 0.75rem; right: 0.75rem; }
    .ci-tl { top: 0.75rem; left: 0.75rem; }
    .ci-br { bottom: 0.75rem; right: 0.75rem; }
    .ci-bl { bottom: 0.75rem; left: 0.75rem; }
    
    /* Character Animations */
    .animated-character { position: absolute; bottom: -20px; width: 180px; height: auto; z-index: 5; pointer-events: none; animation: floatVertical 4s ease-in-out infinite; mix-blend-mode: multiply; filter: contrast(1.1); }
    .boy-character { right: 5%; }
    .girl-character { left: 5%; }
    @@keyframes floatVertical { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="logo-container" onclick="window.location.href='/'" style="cursor: pointer;">
      <img src="~/images/logo.png" alt="Manhaj" style="height: 80px; width: auto;">
    </div>
    <div class="nav-links">
      <a class="nav-link" onclick="scrollToSection('hero')">الرئيسية</a>
      <a class="nav-link" onclick="scrollToSection('about')">من نحن</a>
      <a class="nav-link" onclick="scrollToSection('how-it-works')">كيف يعمل</a>
      <a class="nav-link" onclick="scrollToSection('contact')">تواصل معنا</a>
      @if (User.Identity.IsAuthenticated)
      {
          var role = User.IsInRole("Student") ? "Student" : (User.IsInRole("Teacher") ? "Teacher" : "Admin");
          <a class="btn btn-primary btn-small" asp-controller="@role" asp-action="Dashboard">لوحة التحكم</a>
          <a class="nav-link" asp-controller="Account" asp-action="Profile">@User.Identity.Name</a>
      }
      else
      {
          <a class="btn btn-primary btn-small" asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
      }
    </div>
  </nav>

  <!-- Hero Section with Magic Book -->
  <section class="magic-hero-section" id="hero">
    <div class="magic-header">
      <h1 class="magic-title">مرحباً بك في منصة منهج التعليمية</h1>
      <p class="magic-hint">حرّك المؤشر فوق الكتاب 📖</p>
    </div>

    <div class="book-container">
      <div class="book" id="magic-book" onclick="toggleBook(event)">
       <!-- Book Pages Content -->
       <div class="book-pages-content">
        <div class="quran-verse">
         <p class="verse-text" id="quran-text">اقْرَأْ بِاسْمِ رَبِّكَ الَّذِي خَلَقَ</p>
         <p class="verse-number">سورة العلق - الآية 1</p>
        </div>
       </div>
       <div class="book-pages"></div>
       <!-- Book Spine -->
       <div class="book-spine" style="background: linear-gradient(180deg, #1e40af 0%, #1e3a8a 100%);"></div>
       <!-- Book Cover -->
       <div class="book-cover">
        <div class="cover-dec-top"></div>
        <div class="cover-border"></div>
        <img src="~/images/logo.png" alt="منهج" style="width: 120px; height: auto; z-index: 15; transform: translateZ(2px); filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));">
        <div class="book-decoration" style="background: #fbbf24; z-index: 15; transform: translateZ(2px);"></div>
        <span class="book-subtitle" style="color: rgba(191, 219, 254, 1); z-index: 15; transform: translateZ(2px); font-weight: bold;">للتعليم والمعرفة</span>
        <div class="cover-dec-bottom"></div>
        <svg class="cover-icon ci-tr" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15 8L22 9L17 14L18 21L12 18L6 21L7 14L2 9L9 8L12 2Z" /></svg>
        <svg class="cover-icon ci-tl" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15 8L22 9L17 14L18 21L12 18L6 21L7 14L2 9L9 8L12 2Z" /></svg>
        <svg class="cover-icon ci-br" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15 8L22 9L17 14L18 21L12 18L6 21L7 14L2 9L9 8L12 2Z" /></svg>
        <svg class="cover-icon ci-bl" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15 8L22 9L17 14L18 21L12 18L6 21L7 14L2 9L9 8L12 2Z" /></svg>
       </div>
      </div>
    </div>
    
    <!-- Original hero buttons remain fully functional -->
    <div class="hero-buttons" style="margin-top: auto; z-index: 10; position: relative;">
      @if (!User.Identity.IsAuthenticated)
      {
          <a class="btn btn-secondary" asp-controller="Account" asp-action="Register">ابدأ الآن</a>
      }
      else
      {
           var role = User.IsInRole("Student") ? "Student" : (User.IsInRole("Teacher") ? "Teacher" : "Admin");
          <a class="btn btn-secondary" asp-controller="@role" asp-action="Dashboard">اذهب إلى لوحة التحكم</a>
      }
      <button class="btn btn-outline" style="background: rgba(255,255,255,0.1); color: white; border-color: white;" onclick="scrollToSection('how-it-works')">اكتشف المزيد</button>
    </div>
  </section>

  <!-- About Section -->
  <section class="section" id="about" style="background: var(--surface-white);">
    <div class="section-header">
      <h2 class="section-title" id="about-title">لماذا تختار منهج؟</h2>
      <p class="section-subtitle" id="about-description">منهج هي منصة تعليمية متكاملة توفر مسارًا منظمًا ومُحكمًا للطلاب نحو التفوق. نجمع بين معلمين مؤهلين ومحتوى تفاعلي عالي الجودة مع متابعة مستمرة لتقدمك</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">👨‍🏫</div>
        <h3 class="feature-title">معلمون مؤهلون</h3>
        <p class="feature-description">نخبة من المعلمين الأكفاء المتخصصين في مختلف المجالات الأكاديمية</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📚</div>
        <h3 class="feature-title">محتوى تفاعلي</h3>
        <p class="feature-description">دروس فيديو عالية الجودة مع مواد تعليمية واختبارات تفاعلية</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3 class="feature-title">متابعة مستمرة</h3>
        <p class="feature-description">تتبع تقدمك الأكاديمي وحصولك على تقارير مفصلة عن أدائك</p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="section" id="how-it-works" style="background: var(--background-gray);">
    <div class="section-header">
      <h2 class="section-title" id="how-title">كيف يعمل منهج؟</h2>
      <p class="section-subtitle">ثلاث خطوات بسيطة للبدء في رحلتك التعليمية</p>
    </div>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">1️⃣</div>
        <h3 class="feature-title">سجّل حسابك</h3>
        <p class="feature-description">أنشئ حسابك كطالب أو معلم في دقائق معدودة</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">2️⃣</div>
        <h3 class="feature-title">اختر دورتك</h3>
        <p class="feature-description">تصفح الدورات المتاحة واختر ما يناسب اهتماماتك</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">3️⃣</div>
        <h3 class="feature-title">ابدأ التعلم</h3>
        <p class="feature-description">شاهد الدروس، تفاعل مع المحتوى، واختبر معلوماتك</p>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats-section">
    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-number" id="home-stat-courses">@ViewBag.CoursesCount</div>
        <div class="stat-label">دورة تعليمية</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="home-stat-teachers">@ViewBag.TeachersCount</div>
        <div class="stat-label">معلم محترف</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" id="home-stat-students">@ViewBag.StudentsCount</div>
        <div class="stat-label">طالب متفوق</div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section" id="contact" style="background: var(--surface-white); position: relative; overflow: hidden;">
    <div class="section-header" style="position: relative; z-index: 10;">
      <h2 class="section-title">تواصل معنا</h2>
      <p class="section-subtitle">لديك استفسار؟ نحن هنا للمساعدة</p>
    </div>
    <div style="max-width: 600px; margin: 0 auto; position: relative; z-index: 10;">
      <div class="dashboard-card">
        <form id="contact-form" onsubmit="handleContactForm(event)">
          <div class="form-group">
            <label class="form-label" for="contact-name">الاسم</label>
            <input type="text" id="contact-name" class="form-input" placeholder="أدخل اسمك" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-email">البريد الإلكتروني</label>
            <input type="email" id="contact-email" class="form-input" placeholder="example@email.com" required dir="ltr" style="text-align: left;">
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-message">رسالتك</label>
            <textarea id="contact-message" class="form-textarea" placeholder="اكتب رسالتك هنا..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%;">إرسال الرسالة</button>
        </form>
      </div>
    </div>
    
    <!-- Animated Characters -->
    <img src="https://png.pngtree.com/png-vector/20240309/ourlarge/pngtree-vector-illustration-of-a-guy-with-a-book-drawn-in-a-png-image_11903838.png" alt="Boy Student" class="animated-character boy-character">
    <img src="https://png.pngtree.com/png-vector/20231215/ourlarge/pngtree-teacher-teaching-young-music-female-teacher-studying-various-subjects-3d-character-png-image_11359558.png" alt="Girl Student" class="animated-character girl-character">
  </section>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <script src="~/js/app.js"></script>

  <!-- Magic Book Scripts -->
  <script>
    const arabicLetters = ['أ', 'ب', 'ت', 'ث', 'ج', 'ح', 'خ', 'د', 'ذ', 'ر', 'ز', 'س', 'ش', 'ص', 'ض', 'ط', 'ظ', 'ع', 'غ', 'ف', 'ق', 'ك', 'ل', 'م', 'ن', 'ه', 'و', 'ي', 'ء', 'ى', 'ة'];
    const goldenColors = ['#fbbf24', '#fcd34d', '#fde047', '#f59e0b', '#d97706', '#ca8a04', '#ffffff'];
    let isBookOpen = false;

    // Toggle book open/close
    function toggleBook(event) {
      if(event) event.stopPropagation();
      const book = document.getElementById('magic-book');
      
      if (!isBookOpen) {
        // Open the book
        book.classList.add('opened');
        isBookOpen = true;
        
        // Create explosion after book opens
        setTimeout(() => {
          createLetterExplosion();
        }, 400);
      } else {
        // Close the book
        book.classList.remove('opened');
        isBookOpen = false;
      }
    }
    
    // Create letter explosion
    function createLetterExplosion() {
      const book = document.getElementById('magic-book');
      const rect = book.getBoundingClientRect();
      const centerX = rect.left + rect.width / 2;
      const centerY = rect.top + rect.height / 2;
      
      for (let i = 0; i < 30; i++) {
        setTimeout(() => { createFloatingLetter(centerX, centerY); }, i * 50);
      }
      for (let i = 0; i < 20; i++) {
        setTimeout(() => { createSparkle(centerX, centerY); }, i * 30);
      }
    }
    
    function createFloatingLetter(startX, startY) {
      const letter = document.createElement('div');
      letter.className = 'floating-letter';
      letter.textContent = arabicLetters[Math.floor(Math.random() * arabicLetters.length)];
      
      const offsetX = (Math.random() - 0.5) * 400;
      const offsetY = (Math.random() - 0.5) * 200;
      
      letter.style.left = (startX + offsetX) + 'px';
      letter.style.top = (startY + offsetY) + 'px';
      letter.style.fontSize = (Math.random() * 40 + 20) + 'px';
      letter.style.color = goldenColors[Math.floor(Math.random() * goldenColors.length)];
      letter.style.animation = `floatUp ${2 + Math.random() * 2}s ease-out forwards`;
      
      document.body.appendChild(letter);
      setTimeout(() => { letter.remove(); }, 4000);
    }
    
    function createSparkle(startX, startY) {
      const sparkle = document.createElement('div');
      sparkle.className = 'sparkle';
      const offsetX = (Math.random() - 0.5) * 200;
      const offsetY = (Math.random() - 0.5) * 200;
      sparkle.style.left = (startX + offsetX) + 'px';
      sparkle.style.top = (startY + offsetY) + 'px';
      sparkle.style.backgroundColor = goldenColors[Math.floor(Math.random() * goldenColors.length)];
      document.body.appendChild(sparkle);
      setTimeout(() => { sparkle.remove(); }, 1000);
    }
  </script>
</body>
</html>

@{
    ViewData["Title"] = "إضافة محاضرة - " + ViewBag.CourseTitle;
}

<section class="section" style="background: var(--background-gray); min-height: 80vh; padding: 40px 20px;">
    <div style="max-width: 800px; margin: 0 auto;">
        <div class="dashboard-card">
            <h2 class="section-title" style="text-align: center; margin-bottom: 10px;">إضافة محاضرة جديدة</h2>
            <p style="text-align: center; color: var(--text-secondary); margin-bottom: 30px;">@ViewBag.CourseTitle</p>
            
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <input type="hidden" name="CourseId" value="@ViewBag.CourseId" />
                
                <div class="form-group">
                    <label class="form-label">عنوان المحاضرة</label>
                    <input type="text" name="Title" class="form-input" placeholder="مثال: الدرس الأول - مقدمة" required />
                </div>

                <div class="form-group">
                    <label class="form-label">وصف المحاضرة</label>
                    <textarea name="Description" class="form-textarea" placeholder="اكتب وصفاً موجزاً عن محتوى المحاضرة..." rows="4" required></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">رابط الفيديو</label>
                    <input type="url" name="VideoUrl" class="form-input" placeholder="https://youtube.com/..." dir="ltr" style="text-align: left;" required />
                    <span style="font-size: 14px; color: var(--text-secondary);">
                        يمكنك استخدام روابط YouTube, Vimeo, أو أي منصة فيديو أخرى
                    </span>
                </div>

                <hr style="margin: 30px 0; border: none; border-top: 1px solid #e0e0e0;" />

                <h3 style="font-size: 18px; margin-bottom: 15px;">إضافة مادة تعليمية (اختياري)</h3>

                <div class="form-group">
                    <label class="form-label">عنوان الملف</label>
                    <input type="text" name="materialTitle" class="form-input" placeholder="مثال: ملخص المحاضرة PDF" />
                </div>

                <div class="form-group">
                    <label class="form-label">اختيار الملف</label>
                    <input type="file" name="file" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 20px; font-size: 18px;">
                    إضافة المحاضرة
                </button>

                <div style="text-align: center; margin-top: 20px;">
                    <a asp-controller="Teacher" asp-action="Course" asp-route-id="@ViewBag.CourseId" style="color: var(--text-secondary);">إلغاء</a>
                </div>
            </form>
        </div>

        <div class="dashboard-card" style="margin-top: 20px; background: #e8f4f8;">
            <h4 style="margin-bottom: 10px;">💡 نصيحة:</h4>
            <p style="color: var(--text-secondary); margin: 0;">
                بعد إضافة المحاضرة، يمكنك إضافة المواد التعليمية (PDF, DOCX) والواجبات من صفحة إدارة الدورة.
            </p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

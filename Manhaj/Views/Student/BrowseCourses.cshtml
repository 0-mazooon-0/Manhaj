@using System.Security.Claims
@model List<Manhaj.Models.Course>
@{
    ViewData["Title"] = "تصفح الدورات";
    Layout = "_DashboardLayout";
}

<section class="section" style="background: var(--background-gray); min-height: 80vh; padding: 40px 20px;">
    <div style="max-width: 1200px; margin: 0 auto;">
        <div class="section-header">
            <h2 class="section-title">الدورات المتاحة</h2>
            <p class="section-subtitle">اختر الدورة المناسبة لك وابدأ رحلتك التعليمية</p>
        </div>

        @if (Model.Any())
        {
            <div class="features-grid">
                @foreach (var course in Model)
                {
                    var userId = int.Parse(User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier));
                    var isEnrolled = course.Course_Registrations.Any(cr => cr.StudentId == userId);
                    
                    <div class="feature-card" style="cursor: pointer; position: relative;">
                        <div class="feature-icon">📚</div>
                        <h3 class="feature-title">@course.Title</h3>
                        <p class="feature-description">@(course.Description ?? "لا يوجد وصف")</p>
                        
                        <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #e0e0e0;">
                            <p style="color: var(--text-secondary); margin-bottom: 8px;">
                                <strong>المعلم:</strong> @course.Teacher.FirstName @course.Teacher.LastName
                            </p>
                            <p style="color: var(--text-secondary); margin-bottom: 8px;">
                                <strong>التخصص:</strong> @course.Teacher.Specialization
                            </p>
                            <p style="color: var(--text-secondary); margin-bottom: 8px;">
                                <strong>المستوى:</strong> @course.Level
                            </p>
                            <p style="color: var(--text-secondary); margin-bottom: 8px;">
                                <strong>عدد المحاضرات:</strong> @course.Lectures.Count
                            </p>
                            @if (!isEnrolled)
                            {
                                <p style="color: var(--text-secondary); margin-bottom: 8px;">
                                    <strong>عدد الطلاب المسجلين:</strong> @course.Course_Registrations.Count
                                </p>
                                <p style="color: var(--primary-color); font-weight: 700; font-size: 20px; margin-top: 10px;">
                                    @course.Price.ToString("N0") جنيه
                                </p>
                            }
                        </div>

                        <div style="margin-top: 20px;">
                            <a class="btn btn-primary" style="width: 100%; display: block; text-align: center;" 
                               asp-controller="Student" asp-action="Course" asp-route-id="@course.Id">
                                عرض التفاصيل
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 60px 20px;">
                <p style="font-size: 18px; color: var(--text-secondary);">لا توجد دورات متاحة حالياً</p>
            </div>
        }
    </div>
</section>

@model Manhaj.Models.Course
@{
    ViewData["Title"] = "شراء دورة - " + Model.Title;
    Layout = "_DashboardLayout";
}

<section class="section" style="background: var(--background-gray); min-height: 80vh; padding: 40px 20px;">
    <div style="max-width: 600px; margin: 0 auto;">
        <div class="dashboard-card">
            @if (TempData["SuccessMessage"] != null)
            {
                <div style="background: #d4edda; color: #155724; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
                    @TempData["SuccessMessage"]
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div style="background: #f8d7da; color: #721c24; padding: 15px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
                    @TempData["ErrorMessage"]
                </div>
            }

            <h2 class="section-title" style="margin-bottom: 20px;">شراء دورة: @Model.Title</h2>
            
            <div style="text-align: center; margin-bottom: 30px;">
                <p style="font-size: 18px; color: #666; margin-bottom: 10px;">سعر الدورة</p>
                <p style="font-size: 36px; font-weight: 700; color: var(--primary-color);">@Model.Price جنيه</p>
            </div>

            <div style="background: #e8f4fd; border: 1px solid #b8daff; padding: 20px; border-radius: 8px; margin-bottom: 30px;">
                <h3 style="color: #004085; margin-bottom: 15px;">الدفع الإلكتروني</h3>
                <p style="color: #004085;">
                    يمكنك الدفع بسهولة وأمان باستخدام بطاقتك الائتمانية. سيتم تفعيل الدورة فوراً بعد إتمام عملية الدفع.
                </p>
            </div>

            <form asp-controller="Student" asp-action="PurchaseCourse" method="post">
                <input type="hidden" name="courseId" value="@Model.Id" />
                
                <div style="display: flex; gap: 15px; justify-content: space-between;">
                    <a asp-controller="Student" asp-action="Course" asp-route-id="@Model.Id" 
                       class="btn btn-outline" style="flex: 1;">
                        إلغاء
                    </a>
                    <button type="submit" class="btn btn-primary" style="flex: 1; background-color: #6772e5; border-color: #6772e5;">
                        <i class="fas fa-credit-card" style="margin-left: 8px;"></i>
                        ادفع الآن
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>
